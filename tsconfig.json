{
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    // "rewriteRelativeImportExtensions": true,
    "target": "ESNext"
  },
  "include": ["./packages"],
}
