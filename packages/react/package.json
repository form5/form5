{
  "name": "@form5/react",
  "description": "React components for accessible forms leveraging HTML5 constratins and validation APIs; performant rendering and state management.",
  "author": "Jacob Smith",
  "license": "ISC",
  "type": "module",
  "version": "4.0.0",
  "keywords": [
    "accessible",
    "constraints validation api",
    "forms",
    "html5",
    "jsx",
    "react"
  ],
  "engines": {
    "node": ">=18.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/form5/form5.git",
    "directory": "packages/react",
    "bugs": "https://github.com/form5/form5/issues",
    "homepage": "https://form5.github.io/react"
  },
  "exports": {
    ".": "./barrel.js",
    "./Button": {
      "default": "./Button/Button.jsx",
      "types": "./Button/Button.d.ts"
    },
    "./Field": {
      "default": "./Field/Field.jsx",
      "types": "./Field/Field.d.ts"
    },
    "./FileInput": {
      "default": "./FileInput/FileInput.jsx",
      "types": "./FileInput/FileInput.d.ts"
    },
    "./Form": {
      "default": "./Form/Form.jsx",
      "types": "./Form/Form.d.ts"
    },
    "./Group": {
      "default": "./Group/Group.jsx",
      "types": "./Group/Group.d.ts"
    },
    "./use-interactive-states": {
      "default": "./use-interactive-states/use-interactive-states.js",
      "types": "./use-interactive-states/use-interactive-states.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "NODE_ENV=test node --no-warnings --import ../../test/register.js --import ../../test/globals.mock.js --import ./dom.setup.js --test --test-coverage-include='**/*.jsx' --test-coverage-exclude='**/*.test.jsx' '*/*.test.jsx'"
  },
  "dependencies": {
    "@form5/utils": "^4.0.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^17.4.3",
    "@nodejs-loaders/css-module": "^1.1.0",
    "@nodejs-loaders/tsx": "^1.1.1",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.3.23",
    "esbuild": "*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "peerDependencies": {
    "clsx": "*",
    "react": "17 - 18",
    "react-dom": "17 - 18"
  }
}
